generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = "postgresql://postgres:admin1234@localhost:5432/deployease"
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  githubId       String?  @unique
  githubUsername String?
  image          String?
  awsAccessKeyId     String?
  awsSecretAccessKey String?
  createdAt      DateTime @default(now())

  projects     Project[]
  deployments  Deployment[] 
  ec2Instances Ec2Instance[]
  services     Service[]
}

model Project {
  id          String       @id @default(cuid())
  name        String
  repoUrl     String
  branch      String       @default("main")
  status      DeployStatus @default(PENDING)
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  deployments Deployment[]
  services    Service[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Deployment {
  id String @id @default(cuid())

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id]) // ✅ Relation fixed

  instanceId String?
  instance   Ec2Instance? @relation(fields: [instanceId], references: [id])

  // Service relationship (for multi-service deployments)
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  repoName      String
  repoUrl       String
  branch        String       @default("main")
  slug          String?
  ec2InstanceId String?
  ec2PublicIp   String?
  keyPairName   String?
  keyMaterial   String? // store private key temporarily (OPTIONAL & encrypted)
  appType       String       @default("node")
  appDirectory  String?
  appPort       Int?
  exposedUrl    String?
  envVars       String?
  autoDeploy    Boolean      @default(false)
  repoSubPath   String?
  repoPath      String?
  entryPoint    String?
  
  // Deployment type: "ec2" or "s3"
  deploymentType String @default("ec2")
  
  // S3 specific fields
  s3BucketName   String?
  s3Region       String?
  s3WebsiteUrl   String?
  
  // Build configuration
  buildCommand   String? // e.g., "npm run build"
  outputDirectory String? // e.g., "dist", "build", "out"
  
  startedAt     DateTime     @default(now())
  createdAt     DateTime     @default(now())
  finishedAt    DateTime?
  status        DeployStatus @default(PENDING)
  logs          String?
  updatedAt     DateTime     @updatedAt
}

enum DeployStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model Ec2Instance {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])
  awsInstanceId     String       @unique
  publicIp          String?
  region            String
  instanceType      String
  securityGroupId   String?
  securityGroupName String?
  keyPairName       String
  keyMaterial       String?
  accessKeyId       String
  secretAccessKey   String
  sshUsername       String       @default("ubuntu")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deployments       Deployment[]
  services          Service[]
}

// Service model for multi-service/monorepo deployments
model Service {
  id String @id @default(cuid())

  // Service identification
  name        String // Service name (e.g., "api", "frontend", "worker")
  displayName String? // Optional display name
  
  // Repository information
  repoUrl     String
  repoName    String
  branch      String @default("main")
  repoSubPath String? // Path to service within monorepo (e.g., "services/api")
  
  // Service configuration
  appType        String @default("node") // node, python, react, static
  appPort        Int? // Port for runtime apps
  entryPoint     String? // Entry point file (e.g., "index.js", "main.py")
  buildCommand   String? // Build command (e.g., "npm run build")
  outputDirectory String? // Output directory for static/React apps
  
  // Environment and deployment
  envVars        String? // Environment variables (JSON string)
  deploymentType String @default("ec2") // "ec2" or "s3"
  
  // Infrastructure resources (per-service isolation)
  targetGroupArn    String? // ALB Target Group ARN
  targetGroupName   String? // Target Group name
  autoScalingGroupName String? // ASG name
  healthCheckPath   String? @default("/health") // Health check endpoint
  healthCheckPort   Int? // Health check port
  
  // API Gateway integration
  apiGatewayRouteKey String? // API Gateway route (e.g., "GET /api/v1/users")
  apiGatewayEndpoint String? // API Gateway endpoint URL
  
  // EC2 instance (if deployed to EC2)
  instanceId String?
  instance   Ec2Instance? @relation(fields: [instanceId], references: [id])
  
  // User and project relationships
  userId String
  user   User   @relation(fields: [userId], references: [id])
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  
  // Status and metadata
  status      DeployStatus @default(PENDING)
  exposedUrl  String? // Public URL for the service
  slug        String? // URL slug/identifier
  
  // S3 specific (for static deployments)
  s3BucketName String?
  s3Region     String?
  s3WebsiteUrl String?
  
  // Scaling configuration
  minInstances Int @default(1)
  maxInstances Int @default(3)
  desiredInstances Int @default(1)
  
  // Observability hooks (design-level, for future use)
  logGroupName String? // CloudWatch Log Group
  metricsNamespace String? // CloudWatch Metrics Namespace
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  deployments Deployment[] // Service can have multiple deployments (for rollback/versioning)
}
